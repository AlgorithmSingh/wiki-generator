# Byte-compiled / optimized / cached Python
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts (e.g. generated by `pip install -e .`)
build/
dist/
sdist/
wheels/
*.egg
*.egg-info/
.eggs/
*.whl
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Secrets / local env (GOOGLE_CLOUD_PROJECT etc. — never commit credentials)
.env
.env.*
!.env.example

# Test / coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyre/
.pytype/

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/

# OS cruft
.DS_Store
Thumbs.db

# Python build-sequence run dossier (transient; not a deliverable)
.sequence/
